# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Database (matches docker-compose.yml postgres service)
DATABASE_URL=postgresql://vdr_user:vdr_password@localhost:5432/insolvency_vdr?schema=public

# Redis (sessions / rate limiting / queues — wired up in later modules)
REDIS_URL=redis://localhost:6379

# Cookies
COOKIE_SECRET=dev-cookie-secret-change-in-production

# Rate limiting
THROTTLE_TTL=900000
THROTTLE_LIMIT=1000
THROTTLE_AUTH_LIMIT=20

# JWT / sessions
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
JWT_REFRESH_REMEMBER_ME_EXPIRES_DAYS=30
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
MAX_CONCURRENT_SESSIONS=3
PASSWORD_RESET_EXPIRES_MINUTES=60
INVITE_EXPIRES_HOURS=72

# Mail — MailHog in dev (see docker-compose.yml), disabled in production
# (docker-compose.prod.yml). MailService (mail.service.ts) is a plain
# nodemailer SMTP transport driven entirely by these variables, so any real
# SMTP provider works here with no code changes — just replace the values
# below with the provider's own settings.
#
# Recommended for production: Resend (resend.com) — free tier comfortably
# covers V1.0's volume (password-reset + invite emails only). Their SMTP
# relay:
#   MAIL_HOST=smtp.resend.com
#   MAIL_PORT=587
#   MAIL_SECURE=false
#   MAIL_USER=resend
#   MAIL_PASSWORD=<your Resend API key>
#   MAIL_FROM_ADDRESS must be on a domain verified in your Resend account —
#   it will silently reject sends from an unverified domain.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_NAME=InsolvencyVDR
MAIL_FROM_ADDRESS=noreply@insolvencyvdr.local

# File storage (local filesystem for V1.0)
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE_BYTES=104857600

# Bootstrap admin (prisma db seed) — change the password after first login
SEED_ORG_NAME=Demo Resolution Professionals LLP
SEED_ORG_SLUG=demo-rp
SEED_ADMIN_EMAIL=admin@insolvencyvdr.local
SEED_ADMIN_PASSWORD=ChangeMe123!
