# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Database (matches docker-compose.yml postgres service)
DATABASE_URL=postgresql://vdr_user:vdr_password@localhost:5432/insolvency_vdr?schema=public

# Redis (sessions / rate limiting / queues — wired up in later modules)
REDIS_URL=redis://localhost:6379

# Cookies
COOKIE_SECRET=dev-cookie-secret-change-in-production

# Rate limiting
THROTTLE_TTL=900000
THROTTLE_LIMIT=1000
THROTTLE_AUTH_LIMIT=20

# JWT / sessions
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
JWT_REFRESH_REMEMBER_ME_EXPIRES_DAYS=30
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
MAX_CONCURRENT_SESSIONS=3
PASSWORD_RESET_EXPIRES_MINUTES=60
INVITE_EXPIRES_HOURS=72
REGISTRATION_VERIFICATION_EXPIRES_HOURS=24

# Mail — two providers, selected by MAIL_PROVIDER:
#   nodemailer (default) — plain SMTP, points at MailHog in dev (see
#     docker-compose.yml). Uses MAIL_HOST/PORT/SECURE/USER/PASSWORD below.
#   resend — the real Resend API (staging/prod). Uses RESEND_API_KEY
#     instead of the MAIL_HOST/PORT/* block. MAIL_FROM_ADDRESS must be on a
#     domain verified in your Resend account — it will silently reject
#     sends from an unverified domain.
MAIL_PROVIDER=nodemailer
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_NAME=Varied Reach
MAIL_FROM_ADDRESS=noreply@insolvencyvdr.local
RESEND_API_KEY=
# From the Resend dashboard once a webhook endpoint is configured pointing
# at https://<host>/api/v1/webhooks/resend — used to verify delivered/
# bounced event signatures. Leave blank until that manual setup is done.
RESEND_WEBHOOK_SECRET=
# Set to "staging" only on the staging environment — prefixes every email
# subject with "[STAGING] " so it's visually distinguishable from
# production even though both send from the same address.
APP_ENVIRONMENT=

# Storage-threshold warning emails (80%/95% of a data room's storage limit;
# 100%/"full" isn't separately configurable)
STORAGE_WARNING_PERCENT=80
STORAGE_CRITICAL_PERCENT=95

# File storage (local filesystem for V1.0)
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE_BYTES=2147483648

# Office document conversion (Word/Excel/PowerPoint -> PDF before preview/
# watermarking) — points at the gotenberg service in docker-compose.yml.
# Default already resolves correctly inside every Compose project (dev/
# staging/prod each get their own isolated network), so this normally
# doesn't need overriding.
GOTENBERG_URL=http://gotenberg:3000
GOTENBERG_TIMEOUT_MS=30000

# Bootstrap admin (prisma db seed) — change the password after first login
SEED_ORG_NAME=Demo Resolution Professionals LLP
SEED_ORG_SLUG=demo-rp
SEED_ADMIN_EMAIL=admin@insolvencyvdr.local
SEED_ADMIN_PASSWORD=ChangeMe123!
